# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# For local PostgreSQL: postgresql://user:password@host:port/database_name?schema=public
DATABASE_URL="postgresql://postgres:1@localhost:5433/proinfo?schema=public"

# Session signing secret — MUST be set in production to a long random string.
# All admin API routes require a valid admin session cookie (set on login).
ADMIN_SESSION_SECRET="proinfo-dev-session-secret-change-in-production"

# Admin credentials format: username:password[:role]
# Role must be "SuperAdmin" or "Editor" (defaults to SuperAdmin / Editor if omitted)
ADMIN_SUPERADMIN="superadmin:Admin123:SuperAdmin"
ADMIN_EDITOR="editor:Editor123:Editor"
# Format: username:password:role
ADMIN_CREDENTIALS="superadmin:Admin123:SuperAdmin,editor:Editor123:Editor"
# JSON array alternative — takes priority over ADMIN_SUPERADMIN / ADMIN_EDITOR if set:
# ADMIN_USERS_JSON='[{"username":"superadmin","password":"...","role":"SuperAdmin"}]'

# Legacy token kept as fallback for ADMIN_SESSION_SECRET when ADMIN_SESSION_SECRET is not set.
# Set ADMIN_SESSION_SECRET explicitly in production and remove this.
NEXT_ADMIN_TOKEN="proinfo-admin-dev-token"
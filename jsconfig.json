

{
    "compilerOptions": {
      "baseUrl": ".",
      "ignoreDeprecations": "5.0",
      "paths": {
        "@assets/*": ["public/assets/*"],
        "@components/*": ["src/components/*"],
        "@data/*": ["src/data/*"],
        "@hooks/*": ["src/hooks/*"],
        "@i18n/*": ["src/i18n/*"],
        "@layout/*": ["src/layout/*"],
        "@lib/*": ["src/lib/*"],
        "@styles/*": ["src/styles/*"],
        "@svg/*": ["src/svg/*"],
        "@ui/*": ["src/ui/*"],
        "@utils/*": ["src/utils/*"],
        "@elements/*": ["src/elements/*"],
        "@lib*": ["src/lib/*"]
      },
      "skipLibCheck": true
    }
  }
  


{
    "compilerOptions": {
      "paths": {
        "@assets/*": ["./public/assets/*"],
        "@components/*": ["./src/components/*"],
        "@data/*": ["./src/data/*"],
        "@hooks/*": ["./src/hooks/*"],
        "@i18n/*": ["./src/i18n/*"],
        "@layout/*": ["./src/layout/*"],
        "@lib/*": ["./src/lib/*"],
        "@styles/*": ["./src/styles/*"],
        "@svg/*": ["./src/svg/*"],
        "@ui/*": ["./src/ui/*"],
        "@utils/*": ["./src/utils/*"],
        "@elements/*": ["./src/elements/*"],
        "@lib*": ["./src/lib/*"],
        "src/*": ["./src/*"]
      },
      "skipLibCheck": true
    }
  }
  